#  LEYESHJ.COM — Variables de Entorno
#  1. Copia este archivo a  .env
#  2. Rellena con tus credenciales reales de Supabase
#  3. Agrega estas mismas variables en Render.com → Environment
#  ¡NUNCA subas el .env real a GitHub!
# ══════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────
# Project Settings → API → Project URL
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co

# Project Settings → API → service_role (secret)  ← NO la anon key
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXX

# Project Settings → Database → Connection String → URI (modo: Transaction)
SUPABASE_DB_URL=postgresql://postgres.XXXXXXXX:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── App ───────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=cambia-por-una-clave-secreta-larga-y-aleatoria
